# Scientific Research Agent — Environment Configuration
# Copy this file to .env and edit the paths for your system.
#
#   cp .env.example .env

# Project paths — update these for your system
export SCIRES_REPO_ROOT="/path/to/this/repo"
export SCIRES_RUNTIME_ROOT="/path/to/this/repo/runtime"
export SCIRES_VENV="/path/to/your/python-venv"

# Ollama (local LLM)
export OLLAMA_HOST="127.0.0.1:11434"
export OLLAMA_MODEL="qwen3.5:9b-q4_K_M"        # Change to your preferred model
export OLLAMA_NUM_THREADS=4                      # Adjust for your CPU
export OLLAMA_NUM_PARALLEL=1
export OLLAMA_MAX_LOADED_MODELS=1
export OLLAMA_KEEP_ALIVE="2m"                    # Auto-unload after idle

# GROBID (PDF bibliographic extraction)
export GROBID_URL="http://localhost:8070"

# Query API endpoint
export SCIRES_QUERY_PORT=8099
# export SCIRES_API_KEY="changeme"               # Uncomment for token auth

# Homebrew PATH (macOS only)
# eval "$(/opt/homebrew/bin/brew shellenv)"
